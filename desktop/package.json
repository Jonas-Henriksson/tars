{
  "name": "tars-desktop",
  "version": "1.0.0",
  "description": "TARS Desktop Overlay Widget",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "@picovoice/porcupine-node": "^3.0.0",
    "@picovoice/pvrecorder-node": "^1.2.8"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.tars.desktop",
    "productName": "TARS",
    "win": {
      "target": "nsis",
      "icon": "renderer/icons/tars-icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ]
  }
}
